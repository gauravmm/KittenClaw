{
  "name": "kittenclaw",
  "image": "mcr.microsoft.com/devcontainers/python:3.14",
  "features": {
    "ghcr.io/astral-sh/uv:0.4.4": {}
  },
  "postCreateCommand": "uv sync && cp -n .env.example .env || true",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.debugpy",
        "astral-sh.uv",
        "lehoanganh298.json-lines-viewer",
        "DavidAnson.vscode-markdownlint"
      ],
      "settings": {
        "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python"
      }
    }
  }
}
