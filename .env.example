# Telegram bot token - get one from @BotFather on Telegram.
TELEGRAM_BOT_TOKEN=

# OpenRouter API key - sign up free at https://openrouter.ai/
# Used by the default `openrouter-free` preset.
OPENROUTER_API_KEY=

# Cerebras API key - free signup at https://cloud.cerebras.ai/
# Used by the `cerebras` preset. Only needed if you pass --preset cerebras.
CEREBRAS_API_KEY=

# NVIDIA API key - free signup at https://build.nvidia.com/
# Used by the `nvidia-nim` preset. Only needed if you pass --preset nvidia-nim.
NVIDIA_API_KEY=
