# Secrets
.env

# Original logo source — only the optimized .webp is tracked
kittenclaw_orig.png

# Runtime conversation state (per-student, ephemeral)
conversations/*.jsonl
conversations/archive/*.jsonl

# Runtime model notes (written by the memory tools at chat time)
workspace/memory/*
!workspace/memory/.gitkeep


# Python bytecode
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg

# uv / virtualenv
.venv/
venv/
env/

# Test / type-check / lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Jupyter / IPython
.ipynb_checkpoints/
.python-history

# OS junk
.DS_Store
Thumbs.db
